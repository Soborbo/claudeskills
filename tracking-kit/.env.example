# Tracking-kit env contract.
# Copy to your project's .env / .env.local and fill in real values.
# Set `META_CAPI_TEST_EVENT_CODE` only during validation — REMOVE before going live.

# Client-visible (must be public-prefixed for the bundler that needs it)
GTM_ID=GTM-XXXXXXX
PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Server-side (secrets — store as secret env vars)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# Validation only — REMOVE before production.
META_CAPI_TEST_EVENT_CODE=
