{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["vitest/globals", "node"],
    "baseUrl": ".",
    "paths": {
      "@/lib/tracking/*": ["src/lib/tracking/*"],
      "next/server": ["tests/_stubs/next-server.ts"]
    }
  },
  "include": [
    "src/lib/tracking/**/*.ts",
    "src/api/nextjs/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tests/e2e/**/*",
    "src/api/astro/**/*",
    "src/examples/**/*"
  ]
}
