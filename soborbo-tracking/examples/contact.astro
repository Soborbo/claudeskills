---
// Example contact page with TrackedForm. On submit: dataLayer push (GTM) + the
// event_id hidden field travels with the POST to /api/lead. The SERVER leg is
// dispatched by the /api/lead API route (sendGatewayConversion with that same
// event_id — see server/backend/README.md); the browser does NOT post form
// conversions to the gateway. PII never enters the dataLayer.
import Layout from './Layout.astro';
import TrackedForm from '../components/TrackedForm.astro';
import PhoneLink from '../components/PhoneLink.astro';
---
<Layout>
  <main>
    <h1>Contact</h1>

    <TrackedForm action="/api/lead" eventType="lead" contentName="Contact form">
      <label>Email <input name="email" type="email" required /></label>
      <label>Phone <input name="phone" type="tel" /></label>
      <button type="submit">Request a quote</button>
    </TrackedForm>

    <p>Or call us: <PhoneLink phone="+36301234567" /></p>
  </main>
</Layout>
