---
// Example layout — copy and adapt. The tracking is just 2 lines.
// (No Turnstile: the tracking path has no token gate — the gateway's Origin
// allow-list + rate limit is the browser-path control.)
import Tracking from '../components/Tracking.astro';
import TrackingNoscript from '../components/TrackingNoscript.astro';

const GTM_ID = 'GTM-XXXXXXX';
const COOKIEYES_ID = 'abcdef123456';
---
<!doctype html>
<html lang="hu">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Tracking gtmId={GTM_ID} cookieYesId={COOKIEYES_ID} />
    <slot name="head" />
  </head>
  <body>
    <TrackingNoscript gtmId={GTM_ID} />
    <slot />
  </body>
</html>
