# Astro site worker — CLIENT side only
# (No Turnstile: the tracking path has no token gate.)

# Market config — set per site (HU vs UK vs …)
#   UK site:   GB / GBP / en
#   HU site:   HU / HUF / hu
PUBLIC_TRACKING_COUNTRY=GB
PUBLIC_TRACKING_CURRENCY=GBP
PUBLIC_TRACKING_LOCALE=en

# BACKEND dispatch + daily smoke cron (Worker vars/secrets, NOT this .env — set
# via wrangler secret put / the dashboard; listed for completeness):
#   TRACKING_GATEWAY_TOKEN  (secret) — per-site token (generate-site.mjs crm-secret.env)
#   SITE_URL                         — https://example.com (the site's own hostname)
#   TRACKING_TEST_LEAD_EMAIL         — the designated synthetic-lead address
#   TRACKING_TEST_EVENT_CODE         — Meta Test Events code for this site's pixel

# IMPORTANT: Meta / Google Ads secrets do NOT go here.
# They live in the separate event-gateway worker KV (Soborbo/Serverside) —
# see server/SETUP-SERVER.md. The Astro site worker only serves pages; the
# /api/event/* route is handled by the gateway worker (same-origin).
