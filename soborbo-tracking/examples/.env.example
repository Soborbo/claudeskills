# Astro site worker — CLIENT side only

# Cloudflare Turnstile (required by the gateway's turnstile_token)
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_your_site_key

# Market config — set per site (HU vs UK vs …)
#   UK site:   GB / GBP / en
#   HU site:   HU / HUF / hu
PUBLIC_TRACKING_COUNTRY=GB
PUBLIC_TRACKING_CURRENCY=GBP
PUBLIC_TRACKING_LOCALE=en

# IMPORTANT: Meta / GA4 / Google Ads secrets do NOT go here.
# They live in the separate event-gateway worker KV (Soborbo/Serverside) —
# see server/SETUP-SERVER.md. The Astro site worker only serves pages; the
# /api/event/* route is handled by the gateway worker (same-origin).
