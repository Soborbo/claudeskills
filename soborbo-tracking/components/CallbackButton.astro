---
/**
 * <CallbackButton /> — CTA with callback tracking (browser dataLayer leg ONLY).
 *
 * `callback_request_submitted` is server-ingress-only: the gateway 403s it on
 * the browser path (TRK-400-017), so this component pushes only the dataLayer
 * event (Pixel/GA4 via GTM). If the callback CTA leads to a real form POST,
 * the site BACKEND dispatches the gateway conversion with the shared event_id
 * (see server/backend/gateway-dispatch.ts).
 */
interface Props { class?: string; type?: 'button' | 'submit'; [key: string]: unknown; }
const { class: cls, type = 'button', ...rest } = Astro.props;
---
<button type={type} class={cls} data-tracking-callback {...rest}>
  <slot>Request a callback</slot>
</button>

<script>
  import { trackCallbackConversion } from '../lib';
  function bind() {
    document.querySelectorAll<HTMLButtonElement>('[data-tracking-callback]').forEach(btn => {
      if (btn.dataset.trackBound) return;
      btn.dataset.trackBound = '1';
      // dataLayer only — the gateway leg (if any) belongs to the form's backend.
      btn.addEventListener('click', () => trackCallbackConversion());
    });
  }
  document.addEventListener('astro:page-load', bind);
  if (document.readyState !== 'loading') bind();
</script>
