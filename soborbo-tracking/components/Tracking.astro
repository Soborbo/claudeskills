---
/**
 * <Tracking /> — Place in Layout <head>.
 * Injects CookieYes, Consent Mode v2, GTM, and auto-init.
 *
 * GTM noscript must go after <body> — use <TrackingNoscript />.
 */
interface Props {
  gtmId: string;
  cookieYesId?: string;
}
const { gtmId, cookieYesId } = Astro.props;
---

{cookieYesId && (
  <script is:inline id="cookieyes" type="text/javascript"
    src={`https://cdn-cookieyes.com/client_data/${cookieYesId}/script.js`} />
)}

<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('consent', 'default', {
    'ad_storage': 'denied', 'ad_user_data': 'denied',
    'ad_personalization': 'denied', 'analytics_storage': 'denied',
    'functionality_storage': 'denied', 'personalization_storage': 'denied',
    /* wait_for_update must be >= the CMP's load/restore time. Most
       production CMPs (CookieYes, Cookiebot, OneTrust) advertise
       2000 ms. With a lower value, a returning consented visitor's
       tags fire under the denied default before their stored choice
       loads — silently losing conversions for the most attributable
       segment of traffic. */
    'security_storage': 'granted', 'wait_for_update': 2000
  });
</script>

<script is:inline define:vars={{ gtmId }}>
  (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer',gtmId);
</script>

<script>
  import {
    initTracking, initScrollTracking,
    trackPhoneConversion, trackEmailConversion, trackWhatsappConversion,
  } from '../lib';

  // Auto-bind tel:/mailto:/WhatsApp links. Each fires BOTH channels (dataLayer +
  // gateway) with a shared event_id. tel:/mailto: are protocol-anchored (^=).
  function bindClicks(selector: string, handler: () => void) {
    document.querySelectorAll<HTMLAnchorElement>(selector).forEach(link => {
      if (link.dataset.trackBound) return;
      link.dataset.trackBound = '1';
      link.addEventListener('click', handler);
    });
  }

  // WhatsApp must be matched by the RESOLVED host, not a substring of the href —
  // otherwise a `mailto:?body=https://wa.me/123` share link (or a blog link that
  // merely contains "whatsapp.com") would fire a false conversion. The anchor's
  // .hostname resolves the URL; tel:/mailto: resolve to an empty host, so they're
  // excluded automatically.
  function bindWhatsapp(handler: () => void) {
    document.querySelectorAll<HTMLAnchorElement>('a[href]').forEach(link => {
      const host = link.hostname;
      const isWhatsapp = host === 'wa.me' || host === 'whatsapp.com' || host.endsWith('.whatsapp.com');
      if (!isWhatsapp || link.dataset.trackBound) return;
      link.dataset.trackBound = '1';
      link.addEventListener('click', handler);
    });
  }

  function setup() {
    initTracking();
    initScrollTracking();
    bindClicks('a[href^="tel:"]', () => trackPhoneConversion());
    bindClicks('a[href^="mailto:"]', () => trackEmailConversion());
    bindWhatsapp(() => trackWhatsappConversion());
  }

  document.addEventListener('astro:page-load', setup);
  if (document.readyState !== 'loading') setup();
</script>
