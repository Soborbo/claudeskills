# Transactional email (primary + fallback). At least one is required.
RESEND_API_KEY=re_...
BREVO_API_KEY=xkeysib-...

# Form anti-spam (optional — when unset, the Turnstile gate is skipped).
TURNSTILE_SECRET_KEY=0x...

# Google Sheets lead backup (optional).
GOOGLE_SERVICE_ACCOUNT_EMAIL=...@...iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----...
GOOGLE_SHEET_ID=1aBcDeFg...

# CRM signed webhook (the server tracking leg). The lead is delivered here; the
# CRM stores it and — via the shared event_id — dispatches the ad conversion to
# the event-gateway through its durable outbox. DORMANT until all three are set
# (an unconfigured CRM never fails a submission). CRM_WEBHOOK_SECRET is a secret
# (`wrangler secret put`); the URL/company id are non-secret vars (wrangler.jsonc).
CRM_BASE_URL=https://crm.example.com
CRM_COMPANY_ID=cmp_...
CRM_WEBHOOK_SECRET=whsec_...
# Optional envelope `source` label (defaults to "website").
CRM_WEBHOOK_SOURCE=website
