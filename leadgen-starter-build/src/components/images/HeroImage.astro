---
/**
 * HeroImage — 100vw, eager, fetchpriority high
 * Wraps Picture with LCP-optimized defaults
 */
import Picture from './Picture.astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  class?: string;
  objectPosition?: string;
  aspectRatio?: string;
}

const { src, alt, class: className, objectPosition, aspectRatio } = Astro.props;
---

<Picture
  src={src}
  alt={alt}
  pattern="FULL"
  lcp={true}
  class={className}
  objectPosition={objectPosition}
  aspectRatio={aspectRatio}
/>
