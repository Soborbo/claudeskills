---
import SectionWrapper from '../ui/SectionWrapper.astro';
import { t } from '../../i18n/utils';

interface Step {
  title: string;
  description: string;
}

interface Props {
  heading?: string;
  steps: Step[];
}

const {
  heading = t('services.processHeading'),
  steps,
} = Astro.props;
---

<SectionWrapper id="process" background="white">
  <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-dark)] text-center mb-12">{heading}</h2>

  <div class="max-w-3xl mx-auto space-y-6">
    {steps.map((step, i) => (
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--color-primary-600)] text-white flex items-center justify-center font-bold">
          {i + 1}
        </div>
        <div>
          <h4 class="font-semibold text-[var(--color-dark)] mb-1">{step.title}</h4>
          <p class="text-gray-600">{step.description}</p>
        </div>
      </div>
    ))}
  </div>
</SectionWrapper>
