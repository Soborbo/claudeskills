---
import { config } from '../../config/siteConfig.example';
import { t } from '../../i18n/utils';
import SectionWrapper from '../ui/SectionWrapper.astro';

interface Props {
  heading?: string;
  columns?: 1 | 2 | 3;
  filterService?: string;
  filterArea?: string;
}

const {
  heading = t('testimonials.heading'),
  columns = 3,
  filterService,
  filterArea,
} = Astro.props;

let testimonials = config.testimonials || [];
if (filterService) testimonials = testimonials.filter(item => item.service === filterService);
if (filterArea) testimonials = testimonials.filter(item => item.area === filterArea);

const gridCols = {
  1: 'max-w-lg mx-auto',
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
};

const platformLogos: Record<string, string> = {
  Google: '/images/trust/google-logo.svg',
  Trustpilot: '/images/trust/trustpilot-logo.svg',
  Facebook: '/images/trust/facebook-logo.svg',
};
---

<SectionWrapper id="testimonials" background="light">
  <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-dark)] text-center mb-12">{heading}</h2>

  <div class:list={['grid gap-6', gridCols[columns]]}>
    {testimonials.map(testimonial => (
      <div class="bg-white rounded-xl p-6 shadow-sm hover:-translate-y-0.5 hover:shadow-md transition-all duration-200">
        {/* Stars */}
        <div class="flex text-[var(--color-accent-500)] mb-4">
          {Array.from({ length: 5 }).map(() => (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>

        {/* Quote */}
        <blockquote class="text-gray-700 mb-4 leading-relaxed">
          "{testimonial.quote}"
        </blockquote>

        {/* Author + platform */}
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-[var(--color-primary-100)] flex items-center justify-center text-[var(--color-primary-600)] font-semibold text-sm">
            {testimonial.author.charAt(0)}
          </div>
          <div class="flex-1">
            <p class="font-semibold text-sm text-[var(--color-dark)]">{testimonial.author}</p>
            {testimonial.location && (
              <p class="text-xs text-gray-500">{testimonial.location}</p>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</SectionWrapper>
