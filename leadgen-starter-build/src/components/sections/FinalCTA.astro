---
import { config } from '../../config/siteConfig.example';
import { t } from '../../i18n/utils';
import SectionWrapper from '../ui/SectionWrapper.astro';
import Button from '../ui/Button.astro';

interface Props {
  heading?: string;
  description?: string;
  showPhone?: boolean;
}

const {
  heading = t('finalCta.heading'),
  description = t('finalCta.description'),
  showPhone = true,
} = Astro.props;
---

<SectionWrapper id="final-cta" background="primary" padding="lg">
  <div class="text-center max-w-2xl mx-auto">
    <h2 class="text-2xl sm:text-3xl font-bold mb-4">{heading}</h2>
    <p class="text-white/90 mb-8">{description}</p>

    <Button href="/contact/" variant="secondary" size="lg" dataCta="final-cta" class="bg-white text-[var(--color-primary-600)] hover:bg-gray-100">
      {config.cta.primary}
    </Button>

    <p class="text-sm text-white/70 mt-4">{config.cta.riskReversal}</p>

    {showPhone && (
      <p class="mt-4">
        <a href={`tel:${config.contact.phone}`} class="text-white/80 hover:text-white text-sm">
          Or call us: {config.contact.phoneDisplay}
        </a>
      </p>
    )}
  </div>
</SectionWrapper>
