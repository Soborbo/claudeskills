---
import { config } from '../../config/siteConfig.example';
import { t } from '../../i18n/utils';
import SectionWrapper from '../ui/SectionWrapper.astro';
---

<SectionWrapper id="areas" background="light">
  <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-dark)] text-center mb-12">{t('areas.heading')}</h2>

  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
    {config.areas.map(area => (
      <a
        href={`/areas/${area.slug}/`}
        class="block bg-white rounded-lg p-4 text-center shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 border border-gray-100"
      >
        <p class="font-semibold text-[var(--color-dark)]">{area.name}</p>
        {area.county && <p class="text-xs text-gray-500 mt-1">{area.county}</p>}
      </a>
    ))}
  </div>
</SectionWrapper>
