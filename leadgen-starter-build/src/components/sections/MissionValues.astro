---
import SectionWrapper from '../ui/SectionWrapper.astro';
import { t } from '../../i18n/utils';

interface Value {
  title: string;
  description: string;
}

interface Props {
  heading?: string;
  values: Value[];
}

const {
  heading = t('about.missionHeading'),
  values,
} = Astro.props;
---

<SectionWrapper id="mission-values" background="light">
  <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-dark)] text-center mb-12">{heading}</h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
    {values.map(value => (
      <div class="text-center">
        <h3 class="text-lg font-bold text-[var(--color-dark)] mb-3">{value.title}</h3>
        <p class="text-gray-600">{value.description}</p>
      </div>
    ))}
  </div>
</SectionWrapper>
