---
import { config } from '../../config/siteConfig.example';
import { t } from '../../i18n/utils';
import SectionWrapper from '../ui/SectionWrapper.astro';
---

<SectionWrapper id="credentials" background="light">
  <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-dark)] text-center mb-12">{t('about.credentialsHeading')}</h2>

  <div class="flex flex-wrap justify-center gap-8">
    {config.trust.map(badge => (
      <div class="flex flex-col items-center gap-2">
        {badge.url ? (
          <a href={badge.url} target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">
            {badge.image ? (
              <img src={badge.image} alt={badge.name} loading="lazy" class="h-16 w-auto" />
            ) : (
              <div class="w-16 h-16 rounded-full bg-white border-2 border-gray-200 flex items-center justify-center">
                <svg class="w-8 h-8 text-[var(--color-primary-600)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              </div>
            )}
          </a>
        ) : (
          badge.image ? (
            <img src={badge.image} alt={badge.name} loading="lazy" class="h-16 w-auto" />
          ) : (
            <div class="w-16 h-16 rounded-full bg-white border-2 border-gray-200 flex items-center justify-center">
              <svg class="w-8 h-8 text-[var(--color-primary-600)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
          )
        )}
        <span class="text-sm font-medium text-[var(--color-dark)]">{badge.name}</span>
      </div>
    ))}
  </div>
</SectionWrapper>
