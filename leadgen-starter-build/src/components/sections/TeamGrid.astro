---
import { config } from '../../config/siteConfig.example';
import { t } from '../../i18n/utils';
import SectionWrapper from '../ui/SectionWrapper.astro';
---

<SectionWrapper id="team" background="white">
  <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-dark)] text-center mb-12">{t('about.teamHeading')}</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-4xl mx-auto">
    {config.people.map(person => (
      <div class="text-center">
        {person.image ? (
          <img
            src={person.image}
            alt={person.name}
            loading="lazy"
            class="w-32 h-32 rounded-full object-cover mx-auto mb-4"
          />
        ) : (
          <div class="w-32 h-32 rounded-full bg-[var(--color-primary-100)] flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl font-bold text-[var(--color-primary-600)]">{person.name.charAt(0)}</span>
          </div>
        )}
        <h3 class="font-semibold text-[var(--color-dark)]">{person.name}</h3>
        <p class="text-sm text-gray-500">{person.role}</p>
        {person.bio && <p class="text-sm text-gray-600 mt-2">{person.bio}</p>}
      </div>
    ))}
  </div>
</SectionWrapper>
