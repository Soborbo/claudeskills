---
import { config } from '../../config/siteConfig.example';
import { t } from '../../i18n/utils';
import Button from '../ui/Button.astro';

const quickLinks = [
  { href: '/', label: t('nav.home') },
  { href: '/about/', label: t('nav.about') },
  { href: '/services/', label: t('nav.services') },
  { href: '/contact/', label: t('nav.contact') },
  { href: '/blog/', label: t('nav.blog') },
];

const socialIcons: Record<string, string> = {
  facebook: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
  instagram: '<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>',
  linkedin: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
};
---

<footer class="bg-[var(--color-dark)] text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Col 1: Logo + Description + Social -->
      <div>
        {config.assets.logoDark ? (
          <img src={config.assets.logoDark} alt={config.name} class="h-10 w-auto mb-4" />
        ) : (
          <img src={config.assets.logo} alt={config.name} class="h-10 w-auto mb-4 brightness-0 invert" />
        )}
        <p class="text-sm text-gray-400 mb-6">{config.tagline}</p>
        <div class="flex gap-4">
          {Object.entries(config.social).map(([platform, url]) => {
            if (!url || !socialIcons[platform]) return null;
            return (
              <a
                href={url as string}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-400 hover:text-white transition-colors"
                aria-label={`Visit us on ${platform.charAt(0).toUpperCase() + platform.slice(1)}`}
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <Fragment set:html={socialIcons[platform]} />
                </svg>
              </a>
            );
          })}
        </div>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">{t('footer.quickLinks')}</h3>
        <ul class="space-y-2">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Services -->
      <div>
        <h3 class="text-white font-semibold mb-4">{t('footer.ourServices')}</h3>
        <ul class="space-y-2">
          {config.services.map(service => (
            <li>
              <a href={`/services/${service.slug}/`} class="text-sm text-gray-400 hover:text-white transition-colors">{service.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Areas -->
      <div>
        <h3 class="text-white font-semibold mb-4">{t('footer.areasWeCover')}</h3>
        <ul class="space-y-2">
          {config.areas.slice(0, 8).map(area => (
            <li>
              <a href={`/areas/${area.slug}/`} class="text-sm text-gray-400 hover:text-white transition-colors">{area.name}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-gray-700">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-4 text-sm text-gray-400">
          <a href={`tel:${config.contact.phone}`} class="hover:text-white">{config.contact.phoneDisplay}</a>
          <span class="hidden sm:inline">|</span>
          <a href={`mailto:${config.contact.email}`} class="hover:text-white">{config.contact.email}</a>
        </div>
        <div class="text-sm text-gray-500">{t('footer.copyright')}</div>
        <div class="flex gap-4 text-sm text-gray-400">
          <a href={config.legal.privacyPolicyPath} class="hover:text-white">{t('footer.privacyPolicy')}</a>
          {config.legal.cookiePolicyPath && (
            <a href={config.legal.cookiePolicyPath} class="hover:text-white">{t('footer.cookiePolicy')}</a>
          )}
          {config.legal.termsPath && (
            <a href={config.legal.termsPath} class="hover:text-white">{t('footer.terms')}</a>
          )}
        </div>
      </div>
    </div>
  </div>
</footer>
