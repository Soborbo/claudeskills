---
import { t } from '../../i18n/utils';
---

<div class="error-boundary hidden p-8 text-center" role="alert">
  <h2 class="text-xl font-bold text-[var(--color-dark)] mb-2">{t('errorBoundary.heading')}</h2>
  <p class="text-gray-600 mb-4">{t('errorBoundary.message')}</p>
  <button
    class="px-6 py-2 bg-[var(--color-primary-600)] text-white rounded-lg hover:bg-[var(--color-primary-700)]"
    onclick="window.location.reload()"
  >
    {t('errorBoundary.retry')}
  </button>
</div>
