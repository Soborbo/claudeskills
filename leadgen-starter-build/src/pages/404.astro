---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/navigation/Header.astro';
import Footer from '../components/navigation/Footer.astro';
import Button from '../components/ui/Button.astro';
import { config } from '../config/siteConfig.example';
import { t } from '../i18n/utils';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
  robots="noindex,nofollow"
>
  <Header slot="header" />

  <section class="max-w-2xl mx-auto px-4 py-20 text-center">
    <h1 class="text-6xl font-extrabold text-[var(--color-primary-600)] mb-4">404</h1>
    <h2 class="text-2xl font-bold text-[var(--color-dark)] mb-4">{t('notFound.heading')}</h2>
    <p class="text-gray-600 mb-8">{t('notFound.message')}</p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <Button href="/" variant="primary" size="lg">{t('notFound.cta')}</Button>
      <Button href="/contact/" variant="outline" size="lg">{config.cta.primary}</Button>
    </div>

    <nav class="mt-12" aria-label="Quick navigation">
      <p class="text-sm text-gray-500 mb-4">Or try one of these:</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/services/" class="text-sm text-[var(--color-primary-600)] hover:underline">Services</a>
        <a href="/areas/" class="text-sm text-[var(--color-primary-600)] hover:underline">Areas</a>
        <a href="/about/" class="text-sm text-[var(--color-primary-600)] hover:underline">About</a>
        <a href="/blog/" class="text-sm text-[var(--color-primary-600)] hover:underline">Blog</a>
      </div>
    </nav>
  </section>

  <Footer slot="footer" />
</BaseLayout>
