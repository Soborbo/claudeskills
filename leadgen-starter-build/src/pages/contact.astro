---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/navigation/Header.astro';
import Footer from '../components/navigation/Footer.astro';
import ContactForm from '../components/sections/ContactForm.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Credentials from '../components/sections/Credentials.astro';
import { config } from '../config/siteConfig.example';
import { t } from '../i18n/utils';
import { contactPageSchema } from '../config/schema';

const schema = contactPageSchema(config);
---

<BaseLayout
  title={`Contact ${config.name} — Get a Free Quote`}
  description={`Get in touch with ${config.name} for a free, no-obligation removal quote. Call ${config.contact.phoneDisplay} or request a callback online.`}
  canonicalPath="/contact/"
  schema={schema}
  isContactPage={true}
>
  <Header slot="header" />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Left: info -->
      <div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-[var(--color-dark)] mb-4">{t('contact.heading')}</h1>
        <p class="text-lg text-gray-600 mb-8">{t('contact.subtitle')}</p>

        <!-- Contact info -->
        <div class="space-y-4 mb-8">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[var(--color-primary-600)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href={`mailto:${config.contact.email}`} class="text-[var(--color-primary-600)] font-medium hover:underline">{config.contact.email}</a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href={`tel:${config.contact.phone}`} class="text-gray-600 hover:text-[var(--color-primary-600)]">{config.contact.phoneDisplay}</a>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-400 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <address class="not-italic text-gray-600">
              {config.address.street}<br />
              {config.address.city}, {config.address.postcode}
            </address>
          </div>
        </div>

        <!-- Hours -->
        <div class="mb-8">
          <h2 class="font-semibold text-[var(--color-dark)] mb-3">{t('contact.hoursHeading')}</h2>
          <dl class="space-y-1 text-sm text-gray-600">
            {config.hours.map(h => (
              <div class="flex justify-between">
                <dt>{h.days.join(', ')}</dt>
                <dd class="font-medium">{h.opens} - {h.closes}</dd>
              </div>
            ))}
          </dl>
        </div>

        <!-- Mini reviews -->
        <Testimonials columns={1} />
      </div>

      <!-- Right: form (sticky) -->
      <div>
        <div class="lg:sticky lg:top-[calc(var(--header-h)+20px)]">
          <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-6 lg:p-8">
            <ContactForm />
          </div>
        </div>
      </div>
    </div>
  </section>

  <Credentials />

  <Footer slot="footer" />
</BaseLayout>
