---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/navigation/Header.astro';
import Footer from '../../components/navigation/Footer.astro';
import StickyHeaderCTA from '../../components/cta/StickyHeaderCTA.astro';
import StickyMobileCTA from '../../components/cta/StickyMobileCTA.astro';
import BlogPostList from '../../components/sections/BlogPostList.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
import { config } from '../../config/siteConfig.example';
import { collectionPageSchema } from '../../config/schema';
import { t } from '../../i18n/utils';

// Placeholder posts — in production, from Content Collections
const posts = [
  {
    slug: 'home-removals-guide',
    title: 'The Complete Home Removals Guide for Bristol & Bath',
    description: 'Everything you need to know about moving house in the Bristol area.',
    heroImage: '/images/blog/home-removals-guide.jpg',
    publishDate: '2024-01-15',
    author: 'jay-sheridan',
  },
];

const schema = collectionPageSchema(config, {
  name: 'Blog',
  path: '/blog/',
  items: posts.map(p => ({ name: p.title, url: `/blog/${p.slug}/` })),
});
---

<BaseLayout
  title="Blog — Moving Tips & Guides"
  description={`Moving tips, guides, and advice from ${config.name}. Practical help for your next house or office move.`}
  canonicalPath="/blog/"
  schema={schema}
>
  <Header slot="header" />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-[var(--color-dark)] text-center mb-4">{t('blog.heading')}</h1>
    <p class="text-lg text-gray-600 text-center max-w-2xl mx-auto mb-12">
      Practical advice and tips to make your move easier.
    </p>
  </section>

  <BlogPostList posts={posts} />
  <FinalCTA heading="Need Help With Your Move?" description="Get a free quote and let us take the stress out of moving." />

  <Footer slot="footer" />

  <Fragment slot="cta-overlays">
    <StickyHeaderCTA />
    <StickyMobileCTA />
  </Fragment>
</BaseLayout>
